NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/dsm_dev

# JWT — use long random strings (min 16 chars)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin (CORS)
FRONTEND_URL=http://localhost:5173

# Vodacom Tanzania M-Pesa Open API (required in production)
MPESA_API_KEY=
MPESA_SERVICE_PROVIDER_CODE=

# Transactional email (required in production)
EMAIL_SERVICE_API_KEY=
EMAIL_FROM_ADDRESS=
